{
  "version": 2,
  "functions": {
    "api/search.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/search",
      "dest": "/api/search.js"
    },
    {
      "src": "/fetch",
      "dest": "/api/search.js"
    },
    {
      "src": "/redirect",
      "dest": "/api/search.js"
    },
    {
      "src": "/(.*\\.(png|svg|jpg|jpeg|gif|webp|ico|txt|xml|json))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        }
      ]
    }
  ]
}