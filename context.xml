<?xml version="1.0" encoding="UTF-8"?>
<CustomSearchEngine xmlns="http://www.google.com/cse/schemas/2008/cse-20081211">
  <Title>MGZON Search</Title>
  <Description>Search the entire web from Mark Alasfar's CV</Description>
  <Context>
    <WebSearch enable="true" restrict_to_web="true"/>
  </Context>
  <LookAndFeel>
    <Logo url="https://elasfar.vercel.app/logo.svg" destination="https://elasfar.vercel.app"/>
    <Colors>
      <BackgroundColor>#0f172a</BackgroundColor>
      <TitleColor>#3b82f6</TitleColor>
      <LinkColor>#1e40af</LinkColor>
      <UrlColor>#059669</UrlColor>
      <TextColor>#334155</TextColor>
      <BorderColor>#e2e8f0</BorderColor>
    </Colors>
  </LookAndFeel>
  <ImageSearch enable="true"/>
  <Promotions enable="false"/>
  <SearchPreferences>
    <Language>ar,en</Language>
    <SafeSearch>off</SafeSearch>
    <AutoComplete>true</AutoComplete>
    <!-- No Country/Region = Global Search -->
  </SearchPreferences>
</CustomSearchEngine>